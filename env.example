# ----------------------------------------------------------------------------
# FlowReview environment configuration
# Copy this file to `.env` (cp env.example .env) and adjust values as needed.
# The application runs fully offline with the default fake AI provider.
# ----------------------------------------------------------------------------

# --- API ---
NODE_ENV=development
API_PORT=4000
# Comma-separated list of allowed CORS origins for the web client
CORS_ORIGIN=http://localhost:5173
# Log the full request/description content (development only). Never enable in production.
LOG_VERBOSE_PAYLOADS=false

# --- Database ---
# Used by Prisma. For local dev we default to port 5433 to avoid clashing with a
# PostgreSQL already running on the usual 5432. Start a matching container with:
#   docker run -d --name flowreview-db -e POSTGRES_USER=flowreview \
#     -e POSTGRES_PASSWORD=flowreview -e POSTGRES_DB=flowreview -p 5433:5432 postgres:16-alpine
# (When running via docker-compose the host is `db` and the port is 5432 internally.)
DATABASE_URL=postgresql://flowreview:flowreview@localhost:5433/flowreview?schema=public

# --- AI provider ---
# `fake` (default, deterministic, no external calls) or `openai`.
AI_PROVIDER=fake
# Only used when AI_PROVIDER=openai. Never commit a real key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Retry policy for transient classifier errors
CLASSIFIER_MAX_RETRIES=2
# Confidence threshold below which routing falls back to GENERAL_SUPPORT
ROUTING_CONFIDENCE_THRESHOLD=0.55

# --- Web (Vite) ---
VITE_API_BASE_URL=http://localhost:4000/api
